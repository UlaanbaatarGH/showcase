# Copy to .env.local (gitignored) and fill in real values.
# Supabase → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxx.supabase.co
# Supabase → Project Settings → API → anon public key (safe to expose to client)
VITE_SUPABASE_ANON_KEY=
# Optional: point /api proxy at a local backend while iterating on FastAPI.
# Leave unset to hit the deployed Render backend.
# VITE_API_TARGET=http://127.0.0.1:8000
